<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Timer</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="container">

    <div class="topbar">
      <button class="hamburger" id="btnMenu" aria-label="Open menu">☰</button>
      <h1 class="title">Timer</h1>
      <div class="spacer44"></div>
    </div>

    <!-- Drawer -->
    <div class="backdrop" id="backdrop" aria-hidden="true"></div>
    <aside class="drawer" id="drawer" aria-label="Menu">
      <a href="index.html">Timer</a>
      <a href="entries.html">Entries</a>
      <a href="analytics.html">Analytics</a>
      <a href="export.html">Export / Backup</a>
    </aside>

    <div class="card">
      <div class="row">
        <div class="field">
          <label for="orderInput">Order</label>
          <input id="orderInput" type="text" placeholder="e.g., 104" />
          <div class="smallNote">This stays active until you change it.</div>
        </div>

        <div class="field">
          <label for="taskSelect">Task</label>
          <select id="taskSelect">
            <option value="">— Choose task —</option>
          </select>
          <div class="smallNote">Required before starting.</div>
        </div>
      </div>
    </div>

    <div class="timerWrap">
      <div class="timer" id="timerDisplay">00:00:00</div>
      <button class="bigStart" id="btnStart">START</button>

      <div class="controls">
        <button id="btnPause">Pause</button>
        <button id="btnStop">Stop</button>
      </div>

      <div class="statusLine" id="statusLine"></div>
    </div>

    <div class="card" style="margin-top:14px;">
      <div class="sectionTitle">Today (current order)</div>
      <div style="font-weight:950; font-size:18px;" id="todayTotal">—</div>
      <div class="smallNote" id="todayNote">Totals update after you save a session.</div>

      <div class="sectionTitle" style="margin-top:14px;">Recent sessions</div>
      <div class="list" id="recentList"></div>
    </div>

  </div>

  <!-- Slide-up bead count sheet -->
  <div class="sheetBackdrop" id="sheetBackdrop" aria-hidden="true"></div>
  <div class="sheet" id="sheet" role="dialog" aria-modal="true" aria-label="Bead count">
    <div class="sheetHandle"></div>
    <h2 class="sheetTitle">Bead Count</h2>
    <div class="sheetRow">
      <input id="beadCountInput" type="number" min="0" step="1" inputmode="numeric" placeholder="0" />
      <div class="smallNote" id="beadCountHint">Enter bead count for this session.</div>
      <div class="sheetBtns">
        <button class="btn" id="btnBeadSave">Save</button>
        <button class="btn" id="btnBeadSkip">Skip (0)</button>
      </div>
    </div>
  </div>

  <script src="app.js"></script>
  <script>
    initDrawer();

    // Populate tasks
    const taskSelect = document.getElementById("taskSelect");
    TASKS.forEach(t => {
      const opt = document.createElement("option");
      opt.value = t;
      opt.textContent = t;
      taskSelect.appendChild(opt);
    });

    // Order persistence
    const orderInput = document.getElementById("orderInput");
    orderInput.value = getCurrentOrder();

    orderInput.addEventListener("change", () => {
      setCurrentOrder(orderInput.value);
      refreshTodayAndRecent();
    });

    // Task persistence (last task)
    const lastTask = getLastTask();
    if (lastTask && TASKS.includes(lastTask)) taskSelect.value = lastTask;

    taskSelect.addEventListener("change", () => {
      setLastTask(taskSelect.value);
    });

    // Timer state
    let tick = null;
    let isRunning = false;
    let isPaused = false;
    let startEpochMs = null;
    let pausedAccumMs = 0;
    let pauseStartMs = null;

    // Pending entry info (stop -> maybe bead count sheet -> save)
    let pendingStop = null;

    const timerDisplay = document.getElementById("timerDisplay");
    const statusLine = document.getElementById("statusLine");
    const btnStart = document.getElementById("btnStart");
    const btnPause = document.getElementById("btnPause");
    const btnStop = document.getElementById("btnStop");

    // Sheet elements
    const sheetBackdrop = document.getElementById("sheetBackdrop");
    const sheet = document.getElementById("sheet");
    const beadCountInput = document.getElementById("beadCountInput");
    const btnBeadSave = document.getElementById("btnBeadSave");
    const btnBeadSkip = document.getElementById("btnBeadSkip");

    function elapsedMsNow(){
      if (!startEpochMs) return 0;
      const now = Date.now();
      const base = now - startEpochMs - pausedAccumMs;
      if (isPaused && pauseStartMs){
        // freeze time during pause
        return (pauseStartMs - startEpochMs - pausedAccumMs);
      }
      return Math.max(0, base);
    }

    function setStatus(msg){ statusLine.textContent = msg || ""; }

    function renderTimer(){
      timerDisplay.textContent = msToHMS(elapsedMsNow());
    }

    function startTicker(){
      if (tick) clearInterval(tick);
      tick = setInterval(renderTimer, 250);
    }

    function stopTicker(){
      if (tick) clearInterval(tick);
      tick = null;
    }

    function ensureCanStart(){
      const order = String(orderInput.value || "").trim();
      const task = String(taskSelect.value || "").trim();
      if (!order){
        setStatus("Set an Order first.");
        orderInput.focus();
        return false;
      }
      if (!task){
        setStatus("Select a Task first.");
        taskSelect.focus();
        return false;
      }
      return true;
    }

    function openSheet(){
      sheetBackdrop.classList.add("open");
      sheet.classList.add("open");
      beadCountInput.value = "";
      beadCountInput.focus();
    }

    function closeSheet(){
      sheetBackdrop.classList.remove("open");
      sheet.classList.remove("open");
    }

    sheetBackdrop.addEventListener("click", () => {
      // If user taps outside, treat as Skip(0) to keep flow moving
      commitPendingWithBeads(0);
    });

    function commitPendingWithBeads(beadCount){
      if (!pendingStop) return;
      const entry = pendingStop;
      entry.bead_count = safeParseInt(beadCount, 0);

      addEntry(entry);

      pendingStop = null;
      closeSheet();
      refreshTodayAndRecent();
      setStatus("Saved.");
    }

    // Safety: warn on unload if running
    window.addEventListener("beforeunload", (e) => {
      if (isRunning){
        e.preventDefault();
        e.returnValue = "";
      }
    });

    btnStart.addEventListener("click", () => {
      if (isRunning) return;
      if (!ensureCanStart()) return;

      // Start fresh
      isRunning = true;
      isPaused = false;
      startEpochMs = Date.now();
      pausedAccumMs = 0;
      pauseStartMs = null;

      startTicker();
      renderTimer();
      setStatus(`Running: Order ${orderInput.value.trim()} • ${taskSelect.value}`);
      btnPause.textContent = "Pause";
    });

    btnPause.addEventListener("click", () => {
      if (!isRunning) return;

      if (!isPaused){
        // pause
        isPaused = true;
        pauseStartMs = Date.now();
        btnPause.textContent = "Resume";
        setStatus("Paused.");
      } else {
        // resume
        isPaused = false;
        const now = Date.now();
        pausedAccumMs += (now - pauseStartMs);
        pauseStartMs = null;
        btnPause.textContent = "Pause";
        setStatus(`Running: Order ${orderInput.value.trim()} • ${taskSelect.value}`);
      }
      renderTimer();
    });

    btnStop.addEventListener("click", () => {
      if (!isRunning) return;

      // finalize times
      const endEpoch = Date.now();
      let durationMs = elapsedMsNow();

      // reset timer state immediately (so user can start again after save)
      isRunning = false;
      isPaused = false;
      stopTicker();

      const startDate = new Date(startEpochMs);
      const endDate = new Date(endEpoch);

      const order = orderInput.value.trim();
      const task = taskSelect.value;

      pendingStop = {
        id: uuid(),
        order,
        task,
        date: formatDateMMDDYYYY(endDate),
        start_time: formatTimeHHMMSS(startDate),
        end_time: formatTimeHHMMSS(endDate),
        duration_ms: Math.max(0, durationMs),
        bead_count: 0 // default; may be overwritten
      };

      // reset visual timer
      startEpochMs = null;
      pausedAccumMs = 0;
      pauseStartMs = null;
      timerDisplay.textContent = "00:00:00";
      btnPause.textContent = "Pause";

      // bead count sheet logic
      if (TASKS_REQUIRE_BEAD_COUNT.has(task)){
        setStatus("Enter bead count (or Skip).");
        openSheet();
      } else {
        // Airbrush: no sheet, commit with 0
        commitPendingWithBeads(0);
      }
    });

    btnBeadSave.addEventListener("click", () => {
      commitPendingWithBeads(beadCountInput.value);
    });
    btnBeadSkip.addEventListener("click", () => {
      commitPendingWithBeads(0);
    });

    // Today + recent
    const todayTotalEl = document.getElementById("todayTotal");
    const todayNoteEl = document.getElementById("todayNote");
    const recentList = document.getElementById("recentList");

    function refreshTodayAndRecent(){
      const order = getCurrentOrder() || orderInput.value.trim();
      const entries = loadEntries().slice().reverse(); // newest first

      // Today total (for current order)
      const today = todayMMDDYYYY();
      const todayMs = entries
        .filter(e => e.date === today && String(e.order) === String(order))
        .reduce((a,e) => a + (e.duration_ms || 0), 0);

      todayTotalEl.textContent = order ? `${msToHuman(todayMs)} (Order ${order})` : msToHuman(todayMs);
      todayNoteEl.textContent = order ? `Date: ${today}` : "Set an order to see order-specific totals.";

      // Recent sessions (last 3)
      recentList.innerHTML = "";
      const recent = entries.slice(0, 3);
      if (recent.length === 0){
        const div = document.createElement("div");
        div.className = "smallNote";
        div.textContent = "No sessions yet.";
        recentList.appendChild(div);
        return;
      }

      for (const e of recent){
        const wrap = document.createElement("div");
        wrap.className = "entry";
        wrap.innerHTML = `
          <div class="left">
            <div class="main">Order ${e.order} • ${e.task}</div>
            <div class="meta">${e.date} • ${e.start_time}–${e.end_time}</div>
          </div>
          <div class="right">
            <div class="badge">${msToHuman(e.duration_ms || 0)}</div>
            <div class="badge">Beads: ${Number.isFinite(e.bead_count) ? e.bead_count : 0}</div>
          </div>
        `;
        recentList.appendChild(wrap);
      }
    }

    refreshTodayAndRecent();
  </script>
</body>
</html>
